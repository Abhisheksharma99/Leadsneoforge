# =============================================================================
# ForgeCadNeo Autonomous Marketing Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Anthropic Claude API (REQUIRED)
# Get your key at: https://console.anthropic.com/
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Reddit API (REQUIRED for Reddit features)
# Create an app at: https://www.reddit.com/prefs/apps/
# Select "script" as the app type.
# -----------------------------------------------------------------------------
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=ForgeCadNeo Marketing Agent v1.0

# -----------------------------------------------------------------------------
# LinkedIn API (OPTIONAL)
# Set up via LinkedIn Developer Portal: https://developer.linkedin.com/
# -----------------------------------------------------------------------------
# LINKEDIN_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Twitter/X API (OPTIONAL)
# Set up via Twitter Developer Portal: https://developer.twitter.com/
# -----------------------------------------------------------------------------
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=
