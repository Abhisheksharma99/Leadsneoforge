# ─── LeadsNeoForge Production Environment ─────────────
# Copy this to .env.production and fill in all values before deploying.
#
# On server: cp .env.production.example .env.production

# ─── Authentication ───────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_GENERATE_A_REAL_SECRET

# Admin credentials
ADMIN_EMAIL=admin@leadsneoforge.com
# Generate hash: node scripts/generate-password-hash.js your-secure-password
ADMIN_PASSWORD_HASH=CHANGE_ME_USE_GENERATE_HASH_SCRIPT
ADMIN_NAME=Admin

# ─── AI Provider (Groq Cloud) ────────────────────────
# Get free key: https://console.groq.com/keys
GROQ_API_KEY=gsk_CHANGE_ME
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Reddit API ───────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=LeadsNeoForge/1.0

# ─── LinkedIn API ─────────────────────────────────────
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# ─── Twitter/X API ────────────────────────────────────
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ─── n8n Workflow Engine ──────────────────────────────
N8N_API_KEY=
N8N_BASE_URL=http://localhost:5678
NEXT_PUBLIC_N8N_BASE_URL=http://localhost:5678

# ─── Data Storage ─────────────────────────────────────
DATA_DIR=/app/data

# ─── Application ──────────────────────────────────────
NEXTAUTH_URL=https://leadsneoforge.neocodehub.com
NEXT_PUBLIC_APP_URL=https://leadsneoforge.neocodehub.com
NODE_ENV=production
PORT=3001
